# ============================================================
# Auto-Agent Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Infrastructure (Postgres + Redis run via: docker compose up -d) ---
DATABASE_URL=postgresql+asyncpg://youruser@localhost:5432/autoagent
REDIS_URL=redis://localhost:6379/0

# --- team-memory (shared org-wide context graph) ---
# Points at the team-memory Postgres on Azure. Password is in 1Password.
# URL-encode special chars: ! → %21
TEAM_MEMORY_DATABASE_URL=postgresql+asyncpg://ergodic:<PASSWORD>@atlas-dev-stg.postgres.database.azure.com:5432/team_memory?ssl=require

# --- Slack (optional) ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# --- Linear (optional) ---
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- GitHub ---
# GITHUB_TOKEN is also used at Docker build time to install the private
# team-memory package from ergodic-ai/team-memory (see Dockerfile + deploy.sh).
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
# Default owner (user or org) for repos that auto-agent creates from a
# description. Leave empty to use the GITHUB_TOKEN's own user account.
GITHUB_OWNER=

# --- Web UI auth ---
# HTTP Basic auth for the web UI and API. Username is "admin".
# Leave empty to disable (e.g. for local dev). REQUIRED if exposing to the internet.
WEB_AUTH_PASSWORD=

# --- LLM Provider ---
# One of: "bedrock" (recommended for VM deploys), "anthropic", "claude_cli"
LLM_PROVIDER=bedrock
# Model name (resolved to provider-specific model IDs). Options:
#   claude-sonnet-4-6   — default, best speed/quality balance
#   claude-opus-4-6     — more capable, more expensive
#   claude-haiku-4-5    — cheapest, used for summaries + slug generation
LLM_MODEL=claude-sonnet-4-6

# --- Bedrock auth (if LLM_PROVIDER=bedrock) ---
# Preferred: Bedrock API key from AWS console → Bedrock → API keys.
# Works on any VM with zero AWS tooling installed.
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_REGION=us-east-1

# Alternative: IAM access keys (leave blank if using bearer token above or SSO)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional, only for temporary credentials
# AWS_SESSION_TOKEN=

# --- Anthropic API auth (if LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=

# --- General ---
LOG_LEVEL=INFO
MAX_CONCURRENT_SIMPLE=1
MAX_CONCURRENT_COMPLEX=1
