# ============================================================
# Auto-Agent Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Infrastructure (Postgres + Redis run via: docker compose up -d) ---
DATABASE_URL=postgresql+asyncpg://youruser@localhost:5432/autoagent
REDIS_URL=redis://localhost:6379/0

# --- Slack (optional) ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# --- Linear (optional) ---
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- GitHub ---
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# --- General ---
LOG_LEVEL=INFO
MAX_CONCURRENT_SIMPLE=1
MAX_CONCURRENT_COMPLEX=1
